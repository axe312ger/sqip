{
  "name": "sqip-monorepo",
  "private": true,
  "type": "module",
  "scripts": {
    "prepare": "npm run prepare --workspaces --if-present",
    "build": "npm run build:clean && npm run build -w sqip && npm run build --workspaces --if-present",
    "build:watch": "npm run watch --workspaces --if-present",
    "build:clean": "rm -rf \"packages/*/dist/*\" packages/*/tsconfig.tsbuildinfo",
    "test": "npm run lint && npm run test:unit && npm run test:e2e",
    "test:unit": "TERM=xterm vitest run 'unit' --coverage",
    "test:unit:watch": "TERM=xterm vitest 'unit' --coverage",
    "pretest:e2e": "npm run build",
    "test:e2e": "TERM=xterm vitest run 'e2e'",
    "test:e2e:watch": "TERM=xterm vitest 'e2e'",
    "lint": "eslint packages/*/src",
    "format": "prettier --write 'packages/*/src/**/*.ts' 'packages/*/__tests__/**/*.ts' '**/*.md'",
    "publish": "npm run build && lerna publish --conventional-commits",
    "publish:canary": "npm run publish -- --dist-tag canary"
  },
  "devDependencies": {
    "@vitest/coverage-v8": "^4.0.18",
    "cz-conventional-changelog": "3.3.0",
    "eslint": "^9.39.3",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-prettier": "^5.5.5",
    "husky": "8.0.3",
    "lerna": "^9.0.5",
    "prettier": "^3.8.1",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.56.1",
    "vitest": "^4.0.18"
  },
  "overrides": {
    "gifwrap": "^0.10.1"
  },
  "engines": {
    "node": ">=20.0.0"
  },
  "workspaces": [
    "packages/*",
    "demo"
  ],
  "husky": {
    "hooks": {
      "pre-commit": "npm run lint",
      "pre-push": "npm run test"
    }
  },
  "config": {
    "commitizen": {
      "path": "./node_modules/cz-conventional-changelog"
    }
  },
  "dependencies": {
    "chalk": "^5.6.2"
  }
}
