---
import ImageCard from './ImageCard.astro'

interface Props {
  images: any[]
}

const { images } = Astro.props
---

{images.map((image) => (
  <div class="image-section" data-image={image.filename}>
    <div class="image-header">
      <h2>{image.filename}</h2>
      <span class="image-meta">
        {image.dimensions.width}&times;{image.dimensions.height} &mdash; {(image.originalSize / 1024).toFixed(0)} KB
      </span>
      {image.palette && Object.keys(image.palette).length > 0 && (
        <div class="palette-row">
          {(['Vibrant', 'DarkVibrant', 'LightVibrant', 'Muted', 'DarkMuted', 'LightMuted'] as const).map((key) => {
            const hex = image.palette[key]
            return hex ? (
              <span class="swatch">
                <span class="swatch-color" style={`background:${hex}`} />
                <span class="swatch-text">
                  <span class="swatch-key">{key}</span>
                  <span class="swatch-hex">{hex}</span>
                </span>
              </span>
            ) : null
          })}
        </div>
      )}
    </div>
    <div class="grid">
      {(() => {
        const refSrc = image.referenceImage ? `/processed/${image.referenceImage}` : ''
        const origAR = image.dimensions.width / image.dimensions.height
        return image.results.map((result: any) => (
          <ImageCard
            variantName={result.variantName}
            title={result.title}
            category={result.category}
            pluginChain={result.pluginChain}
            fileName={result.fileName}
            resultFileType={result.resultFileType}
            sizes={result.sizes}
            dimensions={result.dimensions}
            processTimeMs={result.processTimeMs}
            imageSrc={`/processed/${result.fileName}`}
            thumbnailSrc={refSrc}
            configSnippet={result.configSnippet}
            dependencies={result.dependencies}
            originalAspectRatio={origAR}
          />
        ))
      })()}
    </div>
  </div>
))}

<style>
  .image-section {
    margin-bottom: 2.5rem;
  }

  .image-header {
    margin-bottom: 1rem;
    display: flex;
    align-items: baseline;
    gap: 1rem;
    flex-wrap: wrap;
  }

  .image-header h2 {
    font-size: 1.1rem;
    font-weight: 600;
  }

  .image-meta {
    font-size: 0.8rem;
    color: var(--text-muted);
    font-family: var(--font-mono);
  }

  .palette-row {
    display: flex;
    gap: 6px;
    align-items: center;
    flex-wrap: wrap;
    width: 100%;
    margin-top: 0.25rem;
  }

  .swatch {
    display: inline-flex;
    align-items: center;
    gap: 5px;
    cursor: default;
  }

  .swatch-color {
    width: 14px;
    height: 14px;
    border-radius: 3px;
    border: 1px solid var(--border);
    flex-shrink: 0;
  }

  .swatch-text {
    display: inline-flex;
    align-items: baseline;
    gap: 3px;
    font-size: 0.65rem;
    font-family: var(--font-mono);
    color: var(--text-muted);
    white-space: nowrap;
  }

  .swatch-key {
    font-weight: 600;
    color: var(--text);
    font-size: 0.6rem;
  }

  .swatch-hex {
    opacity: 0.8;
  }

  .grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(var(--card-size, 280px), 1fr));
    gap: 1rem;
  }
</style>
