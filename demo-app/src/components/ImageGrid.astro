---
import ImageCard from './ImageCard.astro'

interface Props {
  images: any[]
}

const { images } = Astro.props
---

{images.map((image) => (
  <div class="image-section" data-image={image.filename}>
    <div class="grid">
      {(() => {
        const refSrc = image.referenceImage ? `/processed/${image.referenceImage}` : ''
        const origAR = image.dimensions.width / image.dimensions.height
        return image.results.map((result: any) => (
          <ImageCard
            variantName={result.variantName}
            title={result.title}
            category={result.category}
            pluginChain={result.pluginChain}
            fileName={result.fileName}
            resultFileType={result.resultFileType}
            sizes={result.sizes}
            dimensions={result.dimensions}
            processTimeMs={result.processTimeMs}
            imageSrc={`/processed/${result.fileName}`}
            thumbnailSrc={refSrc}
            configSnippet={result.configSnippet}
            dependencies={result.dependencies}
            originalAspectRatio={origAR}
          />
        ))
      })()}
    </div>
  </div>
))}

<style>
  .image-section {
    margin-bottom: 2.5rem;
  }

  .grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(var(--card-size, 280px), 1fr));
    gap: 1rem;
  }
</style>
