---
import { readFileSync, existsSync } from 'node:fs'
import { resolve } from 'node:path'
import Layout from '../layouts/Layout.astro'
import PluginChainBadge from '../components/PluginChainBadge.astro'

const datasetPath = resolve(process.cwd(), 'generated', 'dataset.json')
let dataset: any[] = []
if (existsSync(datasetPath)) {
  dataset = JSON.parse(readFileSync(datasetPath, 'utf-8'))
}

const blurVariants = ['blur-none', 'blur-legacy', 'blur-css', 'blur-browser']

const imageThumbs = dataset.map((img: any) => {
  const thumb = img.results.find((r: any) => r.variantName === 'thumbnail')
  return {
    name: img.filename as string,
    src: thumb ? `/processed/${thumb.fileName}` : '',
  }
})

function fmtB(bytes: number): string {
  if (bytes === 0) return '0 B'
  if (bytes < 1024) return `${bytes} B`
  if (bytes < 1024 * 1024) return `${(bytes / 1024).toFixed(1)} KB`
  return `${(bytes / (1024 * 1024)).toFixed(1)} MB`
}
---

<Layout title="Blur Test — SQIP Demo">
  <div class="container">
    <header>
      <h1>Blur Test</h1>
      <p class="subtitle">
        Compare different blur techniques: no blur, legacy SVG feGaussianBlur,
        CSS blur applied inside the SVG by the plugin, and CSS blur applied on
        the <code>&lt;img&gt;</code> element by the browser.
      </p>
    </header>

    {dataset.length === 0 ? (
      <div class="empty-state">
        <h2>No data generated yet</h2>
        <p>Run the data generation script first:</p>
        <pre><code>cd demo-app && npm run generate</code></pre>
      </div>
    ) : (
      <>
        <div class="image-selector">
          <h3>Source Image</h3>
          <div class="image-thumbs" id="image-thumbs">
            {imageThumbs.map((thumb, i) => (
              <button
                class={`thumb-btn${i === 0 ? ' active' : ''}`}
                data-image-select={thumb.name}
                title={thumb.name}
                type="button"
              >
                <img src={thumb.src} alt={thumb.name} loading="lazy" />
              </button>
            ))}
          </div>
        </div>

        {dataset.map((image) => {
          const refSrc = image.referenceImage ? `/processed/${image.referenceImage}` : ''
          const origAR = image.dimensions.width / image.dimensions.height
          const results = image.results.filter((r: any) => blurVariants.includes(r.variantName))

          return (
            <div class="image-section" data-image={image.filename}>
              <div class="blur-grid">
                {results.map((result: any) => (
                  <div class="blur-card" data-variant={result.variantName}>
                    <div class="card-image" style={`aspect-ratio: ${origAR};`}>
                      <img
                        class="preview"
                        src={`/processed/${result.fileName}`}
                        alt={result.title}
                        loading="lazy"
                      />
                      {refSrc && (
                        <img class="thumbnail-hover" src={refSrc} alt="" loading="lazy" />
                      )}
                    </div>
                    <div class="card-info">
                      <div class="card-title">{result.title}</div>
                      <PluginChainBadge chain={result.pluginChain} category={result.category} />
                      <div class="card-stats">
                        <span class="stat">Raw: {fmtB(result.sizes.originalBytes)}</span>
                        <span class="stat">Gzip: {fmtB(result.sizes.gzipBytes)}</span>
                        <span class="stat">Brotli: {fmtB(result.sizes.brotliBytes)}</span>
                        <span class="stat">Time: {result.processTimeMs}ms</span>
                      </div>
                      <p class="card-desc">{result.configSnippet && (
                        <pre class="config-snippet"><code>{result.configSnippet}</code></pre>
                      )}</p>
                    </div>
                  </div>
                ))}
              </div>
            </div>
          )
        })}
      </>
    )}
  </div>

  <script is:inline>
    (function() {
      var thumbBtns = document.querySelectorAll('[data-image-select]')
      if (thumbBtns.length === 0) return

      var selectedImage = thumbBtns[0].dataset.imageSelect

      function updateImageSections() {
        document.querySelectorAll('.image-section').forEach(function(section) {
          section.style.display = section.dataset.image === selectedImage ? '' : 'none'
        })
      }

      thumbBtns.forEach(function(btn) {
        btn.addEventListener('click', function() {
          selectedImage = btn.dataset.imageSelect
          thumbBtns.forEach(function(b) { b.classList.remove('active') })
          btn.classList.add('active')
          updateImageSections()
        })
      })

      // Apply CSS blur on the browser-blur variant cards
      document.querySelectorAll('.blur-card[data-variant="blur-browser"] .preview').forEach(function(img) {
        img.style.filter = 'blur(12px)'
      })

      updateImageSections()
    })()
  </script>
</Layout>

<style>
  header {
    margin-bottom: 1.5rem;
  }

  .subtitle {
    color: var(--text-muted);
    font-size: 1rem;
    margin: 0;
  }

  .subtitle code {
    background: var(--tag-bg);
    padding: 0.1rem 0.4rem;
    border-radius: 3px;
    font-size: 0.9em;
    font-family: var(--font-mono);
  }

  .empty-state {
    text-align: center;
    padding: 4rem 2rem;
    background: var(--bg-card);
    border: 2px dashed var(--border);
    border-radius: var(--radius);
  }

  .empty-state h2 {
    border-bottom: none;
  }

  .empty-state pre {
    background: var(--tag-bg);
    padding: 1rem;
    border-radius: 6px;
    display: inline-block;
    font-family: var(--font-mono);
  }

  .image-selector {
    background: var(--bg-card);
    border: 1px solid var(--border);
    border-radius: var(--radius);
    padding: 1.25rem;
    margin-bottom: 1.5rem;
    box-shadow: var(--shadow);
  }

  .image-selector h3 {
    font-size: 0.75rem;
    text-transform: uppercase;
    letter-spacing: 0.05em;
    color: var(--text-muted);
    margin: 0 0 0.5rem;
  }

  .image-thumbs {
    display: flex;
    flex-wrap: wrap;
    gap: 0.5rem;
  }

  .thumb-btn {
    border: 2px solid var(--border);
    border-radius: 6px;
    padding: 0;
    cursor: pointer;
    background: none;
    overflow: hidden;
    opacity: 0.5;
    transition: all 0.15s;
    width: 64px;
    height: 48px;
  }

  .thumb-btn:hover {
    opacity: 0.8;
    border-color: var(--text-muted);
  }

  .thumb-btn.active {
    opacity: 1;
    border-color: var(--accent);
    box-shadow: 0 0 0 2px color-mix(in srgb, var(--accent) 30%, transparent);
  }

  .thumb-btn img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
  }

  .blur-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(320px, 1fr));
    gap: 1.25rem;
    margin-bottom: 2rem;
  }

  .blur-card {
    background: var(--bg-card);
    border: 1px solid var(--border);
    border-radius: var(--radius);
    overflow: hidden;
    box-shadow: var(--shadow);
  }

  .blur-card:hover {
    box-shadow: var(--shadow-lg);
  }

  .card-image {
    position: relative;
    overflow: hidden;
    background: var(--bg-hover);
  }

  .card-image img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
  }

  .preview {
    transition: filter 0.2s ease;
  }

  .thumbnail-hover {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    object-fit: cover;
    opacity: 0;
    transition: opacity 0.3s ease;
    z-index: 1;
  }

  .blur-card:hover .thumbnail-hover {
    opacity: 1;
  }

  .card-info {
    padding: 1rem;
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
  }

  .card-title {
    font-weight: 600;
    font-size: 1rem;
  }

  .card-stats {
    display: flex;
    flex-wrap: wrap;
    gap: 0.75rem;
    font-size: 0.75rem;
    font-family: var(--font-mono);
    color: var(--text-muted);
  }

  .card-desc {
    margin: 0;
  }

  .config-snippet {
    margin: 0;
    padding: 0.75rem;
    background: var(--tag-bg);
    border-radius: 4px;
    overflow-x: auto;
    font-size: 0.7rem;
    line-height: 1.5;
    font-family: var(--font-mono);
    color: var(--text);
  }
</style>
