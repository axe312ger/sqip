---
import { readFileSync, existsSync } from 'node:fs'
import { resolve } from 'node:path'
import Layout from '../layouts/Layout.astro'

const datasetPath = resolve(process.cwd(), 'generated', 'dataset.json')
let dataset: any[] = []
if (existsSync(datasetPath)) {
  dataset = JSON.parse(readFileSync(datasetPath, 'utf-8'))
}

const blurVariants = ['blur-none', 'blur-legacy', 'blur-css', 'blur-browser']
const blurLabels: Record<string, string> = {
  'blur-none': 'No Blur',
  'blur-legacy': 'Legacy SVG Blur',
  'blur-css': 'CSS Blur (Plugin)',
  'blur-browser': 'CSS Blur (Browser)',
}

function fmtB(bytes: number): string {
  if (bytes === 0) return '0 B'
  if (bytes < 1024) return `${bytes} B`
  if (bytes < 1024 * 1024) return `${(bytes / 1024).toFixed(1)} KB`
  return `${(bytes / (1024 * 1024)).toFixed(1)} MB`
}
---

<Layout title="Blur Test — SQIP Demo">
  <div class="container">
    <header>
      <h1>Blur Technique Comparison</h1>
      <p class="subtitle">
        Compare different blur techniques side by side across all images.
        Hover any placeholder to see the original. Notice how browser-applied CSS blur
        bleeds the image edges, while the plugin-applied blur stays clean.
      </p>
    </header>

    {dataset.length === 0 ? (
      <div class="empty-state">
        <h2>No data generated yet</h2>
        <p>Run the data generation script first:</p>
        <pre><code>cd demo-app && npm run generate</code></pre>
      </div>
    ) : (
      <>
        <div class="variant-legend">
          {blurVariants.map((v) => (
            <span class="legend-item">{blurLabels[v]}</span>
          ))}
        </div>

        {dataset.map((image: any) => {
          const refSrc = image.referenceImage ? `/processed/${image.referenceImage}` : ''
          const origAR = image.dimensions.width / image.dimensions.height
          const results = blurVariants
            .map((v: string) => image.results.find((r: any) => r.variantName === v))
            .filter(Boolean)

          return (
            <div class="image-row">
              <div class="image-label">
                <span class="image-name">{image.filename.replace(/-unsplash/, '').replace(/\.\w+$/, '')}</span>
                <span class="image-dims">{image.dimensions.width}&times;{image.dimensions.height}</span>
              </div>
              <div class="blur-columns">
                {results.map((result: any) => (
                  <div class="blur-cell" data-variant={result.variantName}>
                    <div class="cell-image" style={`aspect-ratio: ${origAR};`}>
                      <img
                        class="preview"
                        src={`/processed/${result.fileName}`}
                        alt={result.title}
                        loading="lazy"
                      />
                      {refSrc && (
                        <img class="hover-original" src={refSrc} alt="" loading="lazy" />
                      )}
                    </div>
                    <div class="cell-stats">
                      <span>{fmtB(result.sizes.gzipBytes)} gz</span>
                    </div>
                  </div>
                ))}
              </div>
            </div>
          )
        })}
      </>
    )}
  </div>

  <script is:inline>
    // Apply CSS blur on the browser-blur variant cells
    document.querySelectorAll('.blur-cell[data-variant="blur-browser"] .preview').forEach(function(img) {
      img.style.filter = 'blur(12px)'
    })
  </script>
</Layout>

<style>
  header {
    margin-bottom: 1.5rem;
  }

  .subtitle {
    color: var(--text-muted);
    font-size: 1rem;
    margin: 0;
  }

  .empty-state {
    text-align: center;
    padding: 4rem 2rem;
    background: var(--bg-card);
    border: 2px dashed var(--border);
    border-radius: var(--radius);
  }

  .empty-state h2 {
    border-bottom: none;
  }

  .empty-state pre {
    background: var(--tag-bg);
    padding: 1rem;
    border-radius: 6px;
    display: inline-block;
    font-family: var(--font-mono);
  }

  .variant-legend {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: 0.75rem;
    margin-bottom: 1rem;
    padding: 0.75rem 1rem;
    padding-left: 120px;
    background: var(--bg-card);
    border: 1px solid var(--border);
    border-radius: var(--radius);
    box-shadow: var(--shadow);
  }

  .legend-item {
    font-size: 0.8rem;
    font-weight: 600;
    text-align: center;
    color: var(--text);
  }

  .image-row {
    display: grid;
    grid-template-columns: 100px 1fr;
    gap: 1rem;
    align-items: start;
    margin-bottom: 1rem;
    background: var(--bg-card);
    border: 1px solid var(--border);
    border-radius: var(--radius);
    padding: 0.75rem;
    box-shadow: var(--shadow);
  }

  .image-label {
    display: flex;
    flex-direction: column;
    gap: 0.25rem;
    padding-top: 0.25rem;
  }

  .image-name {
    font-size: 0.75rem;
    font-weight: 600;
    word-break: break-word;
    line-height: 1.3;
  }

  .image-dims {
    font-size: 0.65rem;
    font-family: var(--font-mono);
    color: var(--text-muted);
  }

  .blur-columns {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: 0.75rem;
  }

  .blur-cell {
    display: flex;
    flex-direction: column;
    gap: 0.25rem;
  }

  .cell-image {
    position: relative;
    overflow: hidden;
    border-radius: 6px;
    background: var(--bg-hover);
  }

  .cell-image img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
  }

  .preview {
    transition: opacity 0.3s ease;
  }

  .hover-original {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    object-fit: cover;
    opacity: 0;
    transition: opacity 0.3s ease;
    z-index: 1;
  }

  .blur-cell:hover .hover-original {
    opacity: 1;
  }

  .cell-stats {
    display: flex;
    justify-content: space-between;
    font-size: 0.65rem;
    font-family: var(--font-mono);
    color: var(--text-muted);
    padding: 0 0.25rem;
  }

  @media (max-width: 800px) {
    .variant-legend {
      padding-left: 1rem;
      grid-template-columns: repeat(2, 1fr);
    }

    .image-row {
      grid-template-columns: 1fr;
    }

    .image-label {
      flex-direction: row;
      align-items: baseline;
      gap: 0.5rem;
    }

    .blur-columns {
      grid-template-columns: repeat(2, 1fr);
    }
  }
</style>
