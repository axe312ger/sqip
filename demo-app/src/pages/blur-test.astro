---
import { readFileSync, existsSync } from 'node:fs'
import { resolve } from 'node:path'
import Layout from '../layouts/Layout.astro'

const datasetPath = resolve(process.cwd(), 'generated', 'dataset.json')
let dataset: any[] = []
if (existsSync(datasetPath)) {
  dataset = JSON.parse(readFileSync(datasetPath, 'utf-8'))
}

const blurVariants = ['blur-none', 'blur-legacy', 'blur-css', 'blur-browser']
const blurLabels: Record<string, string> = {
  'blur-none': 'No Blur',
  'blur-legacy': 'SVG Blur (sqip-plugin-blur)',
  'blur-css': 'CSS Blur (sqip-plugin-blur)',
  'blur-browser': 'CSS Blur (Browser)',
}

function fmtB(bytes: number): string {
  if (bytes === 0) return '0 B'
  if (bytes < 1024) return `${bytes} B`
  if (bytes < 1024 * 1024) return `${(bytes / 1024).toFixed(1)} KB`
  return `${(bytes / (1024 * 1024)).toFixed(1)} MB`
}
---

<Layout title="SVG Blur Test — SQIP Demo">
  <div class="container">
    <header>
      <h1>SVG Blur Technique Comparison</h1>
      <p class="subtitle">
        Compare different blur techniques side by side across all images.
        <strong>SVG Blur</strong> and <strong>CSS Blur</strong> (Plugin) are both applied
        by <code>sqip-plugin-blur</code> at build time — one uses an SVG <code>&lt;feGaussianBlur&gt;</code>
        filter, the other a CSS <code>filter: blur()</code> inside the SVG.
        <strong>CSS Blur (Browser)</strong> applies <code>filter: blur()</code> on the
        <code>&lt;img&gt;</code> element at display time — notice how it bleeds the image edges.
      </p>
    </header>

    {dataset.length === 0 ? (
      <div class="empty-state">
        <h2>No data generated yet</h2>
        <p>Run the data generation script first:</p>
        <pre><code>cd demo-app && npm run generate</code></pre>
      </div>
    ) : (
      <>
        <div class="controls-bar">
          <div class="control-group">
            <label class="control-label">Card Size</label>
            <div class="size-toggles" id="size-toggles">
              <button class="size-btn active" data-size="0">Auto</button>
              <button class="size-btn" data-size="150">150px</button>
              <button class="size-btn" data-size="300">300px</button>
              <button class="size-btn" data-size="600">600px</button>
            </div>
          </div>
        </div>



        {dataset.map((image: any) => {
          const refSrc = image.referenceImage ? `/processed/${image.referenceImage}` : ''
          const origAR = image.dimensions.width / image.dimensions.height
          const results = blurVariants
            .map((v: string) => image.results.find((r: any) => r.variantName === v))
            .filter(Boolean)

          return (
            <div class="image-row">
              <div class="image-label">
                <span class="image-name">{image.filename.replace(/-unsplash/, '').replace(/\.\w+$/, '')}</span>
                <span class="image-dims">{image.dimensions.width}&times;{image.dimensions.height}</span>
              </div>
              <div class="blur-columns">
                {results.map((result: any) => (
                  <div class="blur-cell" data-variant={result.variantName}>
                    <div class="cell-image" style={`aspect-ratio: ${origAR};`}>
                      <img
                        class="preview"
                        src={`/processed/${result.fileName}`}
                        alt={result.title}
                        loading="lazy"
                      />
                      {refSrc && (
                        <img class="hover-original" src={refSrc} alt="" loading="lazy" />
                      )}
                    </div>
                    <div class="cell-stats">
                      <span class="cell-title">{blurLabels[result.variantName]}</span>
                      <span class="cell-size">{fmtB(result.sizes.gzipBytes)} gz</span>
                    </div>
                  </div>
                ))}
              </div>
            </div>
          )
        })}
      </>
    )}
  </div>

  <script is:inline>
    // Apply CSS blur on the browser-blur variant cells
    document.querySelectorAll('.blur-cell[data-variant="blur-browser"] .preview').forEach(function(img) {
      img.style.filter = 'blur(12px)'
    })

    // Card size toggles
    var sizeBtns = document.querySelectorAll('.size-btn')
    sizeBtns.forEach(function(btn) {
      btn.addEventListener('click', function() {
        sizeBtns.forEach(function(b) { b.classList.remove('active') })
        btn.classList.add('active')
        var size = parseInt(btn.dataset.size, 10)
        document.querySelectorAll('.blur-columns').forEach(function(grid) {
          if (size === 0) {
            grid.style.gridTemplateColumns = 'repeat(4, 1fr)'
          } else {
            grid.style.gridTemplateColumns = 'repeat(auto-fill, minmax(' + size + 'px, 1fr))'
          }
        })
      })
    })
  </script>
</Layout>

<style>
  header {
    margin-bottom: 1.5rem;
  }

  .subtitle {
    color: var(--text-muted);
    font-size: 1rem;
    margin: 0;
  }

  .empty-state {
    text-align: center;
    padding: 4rem 2rem;
    background: var(--bg-card);
    border: 2px dashed var(--border);
    border-radius: var(--radius);
  }

  .empty-state h2 {
    border-bottom: none;
  }

  .empty-state pre {
    background: var(--tag-bg);
    padding: 1rem;
    border-radius: 6px;
    display: inline-block;
    font-family: var(--font-mono);
  }

  .controls-bar {
    display: flex;
    flex-wrap: wrap;
    gap: 1.5rem;
    margin-bottom: 1rem;
    padding: 0.75rem 1.25rem;
    background: var(--bg-card);
    border: 1px solid var(--border);
    border-radius: var(--radius);
    box-shadow: var(--shadow);
    align-items: center;
    position: sticky;
    top: 0;
    z-index: 11;
  }

  .control-group {
    display: flex;
    align-items: center;
    gap: 0.75rem;
  }

  .control-label {
    font-size: 0.75rem;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.05em;
    color: var(--text-muted);
  }

  .size-toggles {
    display: flex;
    gap: 0.35rem;
  }

  .size-btn {
    padding: 0.3rem 0.6rem;
    border: 1px solid var(--border);
    border-radius: 4px;
    background: var(--bg);
    color: var(--text);
    cursor: pointer;
    font-size: 0.7rem;
    font-family: var(--font);
    transition: border-color 0.15s, box-shadow 0.15s;
  }

  .size-btn:hover {
    border-color: var(--accent);
  }

  .size-btn.active {
    border-color: var(--accent);
    box-shadow: 0 0 0 2px color-mix(in srgb, var(--accent) 30%, transparent);
  }



  .image-row {
    display: grid;
    grid-template-columns: 100px 1fr;
    gap: 1rem;
    align-items: start;
    margin-bottom: 1rem;
    background: var(--bg-card);
    border: 1px solid var(--border);
    border-radius: var(--radius);
    padding: 0.75rem;
    box-shadow: var(--shadow);
  }

  .image-label {
    display: flex;
    flex-direction: column;
    gap: 0.25rem;
    padding-top: 0.25rem;
  }

  .image-name {
    font-size: 0.75rem;
    font-weight: 600;
    word-break: break-word;
    line-height: 1.3;
  }

  .image-dims {
    font-size: 0.65rem;
    font-family: var(--font-mono);
    color: var(--text-muted);
  }

  .blur-columns {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: 0.75rem;
  }

  .blur-cell {
    display: flex;
    flex-direction: column;
    gap: 0.25rem;
  }

  .cell-image {
    position: relative;
    overflow: hidden;
    border-radius: 6px;
    background: var(--bg-hover);
  }

  .cell-image img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
  }

  .preview {
    transition: opacity 0.3s ease;
  }

  .hover-original {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    object-fit: cover;
    opacity: 0;
    transition: opacity 0.3s ease;
    z-index: 1;
  }

  .blur-cell:hover .hover-original {
    opacity: 1;
  }

  .cell-stats {
    display: flex;
    justify-content: space-between;
    align-items: baseline;
    font-size: 0.65rem;
    color: var(--text-muted);
    padding: 0 0.25rem;
  }

  .cell-title {
    font-weight: 600;
    font-size: 0.7rem;
    color: var(--text);
  }

  .cell-size {
    font-family: var(--font-mono);
  }

  @media (max-width: 800px) {
    .image-row {
      grid-template-columns: 1fr;
    }

    .image-label {
      flex-direction: row;
      align-items: baseline;
      gap: 0.5rem;
    }

    .blur-columns {
      grid-template-columns: repeat(2, 1fr);
    }
  }
</style>
