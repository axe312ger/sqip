---
import { readFileSync, existsSync } from 'node:fs'
import { resolve } from 'node:path'
import Layout from '../layouts/Layout.astro'
import FilterBar from '../components/FilterBar.astro'
import StatsPanel from '../components/StatsPanel.astro'
import ImageGrid from '../components/ImageGrid.astro'
import { variants } from '../data/variants'

// Load dataset at build/dev time from the filesystem
const datasetPath = resolve(process.cwd(), 'generated', 'dataset.json')
let dataset: any[] = []
if (existsSync(datasetPath)) {
  dataset = JSON.parse(readFileSync(datasetPath, 'utf-8'))
}

// Filter out blur-test variants (they have their own dedicated page)
const dashboardData = dataset.map((img: any) => ({
  ...img,
  results: img.results.filter((r: any) => r.category !== 'blur-test'),
}))

const dashboardVariants = variants.filter((v) => v.category !== 'blur-test')

// Build thumbnail data for image selector buttons
const imageThumbs = dashboardData.map((img: any) => {
  const thumb = img.results.find((r: any) => r.variantName === 'thumbnail')
  return {
    name: img.filename as string,
    src: thumb ? `/processed/${thumb.fileName}` : '',
    width: thumb?.dimensions?.width ?? 300,
    height: thumb?.dimensions?.height ?? 225,
  }
})
---

<Layout title="SQIP Interactive Demo">
  <div class="container">
    <header>
      <h1>
        SQIP Demo
        <a href="https://github.com/axe312ger/sqip" target="_blank" class="github-link">
          <svg width="24" height="24" viewBox="0 0 16 16" fill="currentColor">
            <path d="M8 0C3.58 0 0 3.58 0 8c0 3.54 2.29 6.53 5.47 7.59.4.07.55-.17.55-.38 0-.19-.01-.82-.01-1.49-2.01.37-2.53-.49-2.69-.94-.09-.23-.48-.94-.82-1.13-.28-.15-.68-.52-.01-.53.63-.01 1.08.58 1.23.82.72 1.21 1.87.87 2.33.66.07-.52.28-.87.51-1.07-1.78-.2-3.64-.89-3.64-3.95 0-.87.31-1.59.82-2.15-.08-.2-.36-1.02.08-2.12 0 0 .67-.21 2.2.82.64-.18 1.32-.27 2-.27.68 0 1.36.09 2 .27 1.53-1.04 2.2-.82 2.2-.82.44 1.1.16 1.92.08 2.12.51.56.82 1.27.82 2.15 0 3.07-1.87 3.75-3.65 3.95.29.25.54.73.54 1.48 0 1.07-.01 1.93-.01 2.2 0 .21.15.46.55.38A8.013 8.013 0 0016 8c0-4.42-3.58-8-8-8z"></path>
          </svg>
        </a>
      </h1>
      <p class="subtitle">
        Interactive comparison of SVG-based image placeholders.
        Generate low-quality image previews with different plugin chains.
      </p>
    </header>

    {dataset.length === 0 ? (
      <div class="empty-state">
        <h2>No data generated yet</h2>
        <p>Run the data generation script first:</p>
        <pre><code>cd demo-app && npm run generate</code></pre>
      </div>
    ) : (
      <>
        <FilterBar />
        <StatsPanel />
        <div class="image-bar" id="image-bar">
          <div class="image-thumbs" id="image-thumbs">
            {imageThumbs.map((thumb, i) => (
              <button
                class={`thumb-btn${i === 0 ? ' active' : ''}`}
                data-image-select={thumb.name}
                title={thumb.name}
                type="button"
              >
                <img src={thumb.src} alt={thumb.name} width={thumb.width} height={thumb.height} loading="lazy" />
              </button>
            ))}
          </div>
          <div class="image-info" id="image-info">
            <h2 id="image-info-name">{dashboardData[0]?.filename ?? ''}</h2>
            <span class="image-meta" id="image-info-meta">
              {dashboardData[0]?.dimensions.width}&times;{dashboardData[0]?.dimensions.height} &mdash; {dashboardData[0] ? (dashboardData[0].originalSize / 1024).toFixed(0) : 0} KB
            </span>
            {dashboardData[0]?.palette && Object.keys(dashboardData[0].palette).length > 0 && (
              <div class="palette-row" id="image-info-palette">
                {(['Vibrant', 'DarkVibrant', 'LightVibrant', 'Muted', 'DarkMuted', 'LightMuted'] as const).map((key) => {
                  const hex = dashboardData[0].palette[key]
                  return hex ? (
                    <span class="swatch">
                      <span class="swatch-color" style={`background:${hex}`} />
                      <span class="swatch-text">
                        <span class="swatch-key">{key}</span>
                        <span class="swatch-hex">{hex}</span>
                      </span>
                    </span>
                  ) : null
                })}
              </div>
            )}
          </div>
        </div>
        <ImageGrid images={dashboardData} />

        <details class="snippets-section">
          <summary>Code Snippets</summary>
          <div class="snippets-grid">
            {dashboardVariants.filter((v) => v.configSnippet).map((v) => (
              <div class="snippet-card">
                <div class="snippet-title">{v.title}</div>
                <pre class="snippet-code"><code>{v.configSnippet}</code></pre>
              </div>
            ))}
          </div>
        </details>
      </>
    )}
  </div>

  <footer class="tracking-footer" id="tracking-footer">
    <span class="tracking-status" id="tracking-status">
      This site uses anonymized analytics to understand how the demo is used.
    </span>
    <button type="button" class="tracking-toggle" id="tracking-toggle">
      Opt out
    </button>
  </footer>

  <script is:inline define:vars={{ dataset: dashboardData }}>
    if (dataset.length > 0) {
      var thumbBtns = document.querySelectorAll('[data-image-select]')
      var selectedImage = thumbBtns.length > 0 ? thumbBtns[0].dataset.imageSelect : ''
      var categoryToggles = document.querySelectorAll('[data-category-toggle]')
      var variantToggles = document.querySelectorAll('[data-variant-toggle]')
      var sizeToggles = document.querySelectorAll('[data-size-toggle]')

      function formatBytes(bytes) {
        if (bytes === 0) return '0 B'
        if (bytes < 1024) return bytes + ' B'
        if (bytes < 1024 * 1024) return (bytes / 1024).toFixed(1) + ' KB'
        return (bytes / (1024 * 1024)).toFixed(1) + ' MB'
      }

      function getVisibleVariants() {
        var visible = new Set()
        variantToggles.forEach(function(cb) {
          if (cb.checked) visible.add(cb.dataset.variantToggle)
        })
        return visible
      }

      function getCurrentImageData() {
        return dataset.find(function(img) { return img.filename === selectedImage }) || dataset[0]
      }

      function updateStats() {
        var visible = getVisibleVariants()
        var imageData = getCurrentImageData()
        var visibleResults = imageData.results.filter(function(r) {
          return visible.has(r.variantName) && r.sizes.gzipBytes > 0
        })

        document.getElementById('stat-count').textContent = visibleResults.length

        if (visibleResults.length === 0) {
          document.getElementById('stat-avg-gzip').textContent = '\u2014'
          document.getElementById('stat-avg-brotli').textContent = '\u2014'
          document.getElementById('stat-avg-time').textContent = '\u2014'
          document.getElementById('stat-smallest').textContent = '\u2014'
          document.getElementById('stat-fastest').textContent = '\u2014'
          return
        }

        var avgGzip = visibleResults.reduce(function(s, r) { return s + r.sizes.gzipBytes }, 0) / visibleResults.length
        var avgBrotli = visibleResults.reduce(function(s, r) { return s + r.sizes.brotliBytes }, 0) / visibleResults.length
        var avgTime = visibleResults.reduce(function(s, r) { return s + r.processTimeMs }, 0) / visibleResults.length
        var smallest = visibleResults.reduce(function(min, r) { return r.sizes.gzipBytes < min.sizes.gzipBytes ? r : min })
        var fastest = visibleResults.reduce(function(min, r) { return r.processTimeMs < min.processTimeMs ? r : min })

        document.getElementById('stat-avg-gzip').textContent = formatBytes(Math.round(avgGzip))
        document.getElementById('stat-avg-brotli').textContent = formatBytes(Math.round(avgBrotli))
        document.getElementById('stat-avg-time').textContent = Math.round(avgTime) + 'ms'
        document.getElementById('stat-smallest').textContent = smallest.title + ' (' + formatBytes(smallest.sizes.gzipBytes) + ')'
        document.getElementById('stat-fastest').textContent = fastest.title + ' (' + fastest.processTimeMs + 'ms)'
      }

      function updateImageSections() {
        document.querySelectorAll('.image-section').forEach(function(section) {
          section.style.display = section.dataset.image === selectedImage ? '' : 'none'
        })
      }

      function updateImageInfo() {
        var img = getCurrentImageData()
        if (!img) return
        document.getElementById('image-info-name').textContent = img.filename
        document.getElementById('image-info-meta').innerHTML = img.dimensions.width + '&times;' + img.dimensions.height + ' &mdash; ' + (img.originalSize / 1024).toFixed(0) + ' KB'
        var paletteEl = document.getElementById('image-info-palette')
        if (paletteEl && img.palette) {
          var keys = ['Vibrant', 'DarkVibrant', 'LightVibrant', 'Muted', 'DarkMuted', 'LightMuted']
          var html = ''
          keys.forEach(function(key) {
            var hex = img.palette[key]
            if (hex) {
              html += '<span class="swatch"><span class="swatch-color" style="background:' + hex + '"></span><span class="swatch-text"><span class="swatch-key">' + key + '</span><span class="swatch-hex">' + hex + '</span></span></span>'
            }
          })
          paletteEl.innerHTML = html
        }
      }

      function updateVisibility() {
        var visible = getVisibleVariants()

        // Show only the selected image section
        updateImageSections()

        // Show/hide individual cards within the visible section
        document.querySelectorAll('.card').forEach(function(card) {
          var name = card.dataset.variant
          card.style.display = visible.has(name) ? '' : 'none'
        })

        updateStats()
      }

      // Category toggle: check/uncheck all variants in that category
      categoryToggles.forEach(function(cb) {
        cb.addEventListener('change', function() {
          var cat = cb.dataset.categoryToggle
          var checked = cb.checked
          variantToggles.forEach(function(vcb) {
            if (vcb.dataset.variantCategory === cat) {
              vcb.checked = checked
            }
          })
          trackEvent('filter', 'category-toggle', cat, checked ? 1 : 0)
          updateVisibility()
        })
      })

      // Individual variant toggle — sync category checkbox
      variantToggles.forEach(function(cb) {
        cb.addEventListener('change', function() {
          var cat = cb.dataset.variantCategory
          var allInCat = Array.from(variantToggles).filter(function(v) { return v.dataset.variantCategory === cat })
          var allChecked = allInCat.every(function(v) { return v.checked })
          var catCb = document.querySelector('[data-category-toggle="' + cat + '"]')
          if (catCb) catCb.checked = allChecked
          trackEvent('filter', 'variant-toggle', cb.dataset.variantToggle, cb.checked ? 1 : 0)
          updateVisibility()
        })
      })

      // Card size toggle
      function applyCardSize(size) {
        document.querySelectorAll('.grid').forEach(function(grid) {
          grid.style.setProperty('--card-size', size + 'px')
        })
      }

      sizeToggles.forEach(function(radio) {
        radio.addEventListener('change', function() {
          if (radio.checked) {
            trackEvent('settings', 'card-size', radio.value + 'px', Number(radio.value))
            applyCardSize(radio.value)
          }
        })
      })

      // Image selector — thumbnail buttons
      thumbBtns.forEach(function(btn) {
        btn.addEventListener('click', function() {
          selectedImage = btn.dataset.imageSelect
          thumbBtns.forEach(function(b) { b.classList.remove('active') })
          btn.classList.add('active')
          trackEvent('navigation', 'image-select', selectedImage)
          updateImageInfo()
          updateVisibility()
        })
      })

      // Track clicks on image cards
      document.querySelectorAll('.card').forEach(function(card) {
        card.addEventListener('click', function() {
          trackEvent('interaction', 'card-click', card.dataset.variant)
        })
      })

      // Initial render — show first image only, apply default card size
      applyCardSize(150)
      updateVisibility()
    }

    // Tracking opt-out toggle
    (function initOptOut() {
      var btn = document.getElementById('tracking-toggle')
      var status = document.getElementById('tracking-status')
      var footer = document.getElementById('tracking-footer')
      if (!btn || !status || !footer) return

      var optedOut = localStorage.getItem('matomo-opt-out') === '1'

      function render() {
        if (optedOut) {
          status.textContent = 'Anonymized analytics are disabled.'
          btn.textContent = 'Opt in'
        } else {
          status.textContent = 'This site uses anonymized analytics to understand how the demo is used.'
          btn.textContent = 'Opt out'
        }
      }

      btn.addEventListener('click', function() {
        optedOut = !optedOut
        if (optedOut) {
          localStorage.setItem('matomo-opt-out', '1')
          if (window._paq) _paq.push(['optUserOut'])
        } else {
          localStorage.removeItem('matomo-opt-out')
          if (window._paq) _paq.push(['forgetUserOptOut'])
        }
        render()
      })

      render()
    })()
  </script>
</Layout>

<style>
  header {
    margin-bottom: 1.5rem;
  }

  h1 {
    display: flex;
    align-items: center;
    gap: 0.75rem;
  }

  .github-link {
    vertical-align: middle;
    opacity: 0.5;
    transition: opacity 0.15s;
  }

  .github-link:hover {
    opacity: 1;
  }

  .empty-state {
    text-align: center;
    padding: 4rem 2rem;
    background: var(--bg-card);
    border: 2px dashed var(--border);
    border-radius: var(--radius);
  }

  .empty-state h2 {
    border-bottom: none;
  }

  .empty-state pre {
    background: var(--tag-bg);
    padding: 1rem;
    border-radius: 6px;
    display: inline-block;
    font-family: var(--font-mono);
  }

  .tracking-footer {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 0.75rem;
    padding: 1rem 2rem;
    margin-top: 2rem;
    font-size: 0.75rem;
    color: var(--text-muted);
    border-top: 1px solid var(--border);
  }

  .tracking-toggle {
    background: none;
    border: 1px solid var(--border);
    border-radius: 4px;
    color: var(--text-muted);
    font-size: 0.75rem;
    padding: 0.2rem 0.6rem;
    cursor: pointer;
    transition: all 0.15s;
  }

  .tracking-toggle:hover {
    color: var(--text);
    border-color: var(--text-muted);
  }

  .snippets-section {
    margin-top: 2rem;
    margin-bottom: 1rem;
    background: var(--bg-card);
    border: 1px solid var(--border);
    border-radius: var(--radius);
    box-shadow: var(--shadow);
    padding: 1rem 1.25rem;
  }

  .snippets-section summary {
    font-weight: 600;
    font-size: 1rem;
    cursor: pointer;
    user-select: none;
    color: var(--text);
  }

  .snippets-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(320px, 1fr));
    gap: 1rem;
    margin-top: 1rem;
  }

  .snippet-card {
    background: var(--tag-bg);
    border-radius: 6px;
    padding: 0.75rem;
    overflow: hidden;
  }

  .snippet-title {
    font-weight: 600;
    font-size: 0.8rem;
    margin-bottom: 0.5rem;
    color: var(--text);
  }

  .snippet-code {
    margin: 0;
    padding: 0;
    background: none;
    overflow-x: auto;
    font-size: 0.65rem;
    line-height: 1.5;
    font-family: var(--font-mono);
    color: var(--text);
  }

  .snippet-code code {
    white-space: pre-wrap;
    word-break: break-word;
  }

  .image-bar {
    position: sticky;
    top: 0;
    z-index: 10;
    background: var(--bg-card);
    border: 1px solid var(--border);
    border-radius: var(--radius);
    padding: 1rem 1.25rem;
    box-shadow: var(--shadow);
    margin-bottom: 1rem;
    display: flex;
    flex-direction: column;
    gap: 0.75rem;
  }

  .image-thumbs {
    display: flex;
    flex-wrap: wrap;
    gap: 0.5rem;
  }

  .thumb-btn {
    border: 2px solid var(--border);
    border-radius: 6px;
    padding: 0;
    cursor: pointer;
    background: none;
    overflow: hidden;
    opacity: 0.5;
    transition: all 0.15s;
    width: 64px;
    height: 48px;
  }

  .thumb-btn:hover {
    opacity: 0.8;
    border-color: var(--text-muted);
  }

  .thumb-btn.active {
    opacity: 1;
    border-color: var(--accent);
    box-shadow: 0 0 0 2px color-mix(in srgb, var(--accent) 30%, transparent);
  }

  .thumb-btn img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
  }

  .image-info {
    display: flex;
    align-items: baseline;
    gap: 1rem;
    flex-wrap: wrap;
  }

  .image-info h2 {
    font-size: 1.1rem;
    font-weight: 600;
    margin: 0;
    border-bottom: none;
    padding-bottom: 0;
  }

  .image-meta {
    font-size: 0.8rem;
    color: var(--text-muted);
    font-family: var(--font-mono);
  }

  .image-bar :global(.palette-row) {
    display: flex;
    gap: 6px;
    align-items: center;
    flex-wrap: wrap;
    width: 100%;
    margin-top: 0.25rem;
  }

  .image-bar :global(.swatch) {
    display: inline-flex;
    align-items: center;
    gap: 5px;
    cursor: default;
  }

  .image-bar :global(.swatch-color) {
    width: 14px;
    height: 14px;
    border-radius: 3px;
    border: 1px solid var(--border);
    flex-shrink: 0;
  }

  .image-bar :global(.swatch-text) {
    display: inline-flex;
    align-items: baseline;
    gap: 3px;
    font-size: 0.65rem;
    font-family: var(--font-mono);
    color: var(--text-muted);
    white-space: nowrap;
  }

  .image-bar :global(.swatch-key) {
    font-weight: 600;
    color: var(--text);
    font-size: 0.6rem;
  }

  .image-bar :global(.swatch-hex) {
    opacity: 0.8;
  }
</style>
